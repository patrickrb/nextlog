FROM node:22-alpine

# Install dependencies for development including PostgreSQL client (for psql CLI)
RUN apk add --no-cache libc6-compat postgresql-client bash

WORKDIR /app

# Copy package files first
COPY package*.json ./

# Install dependencies
RUN npm ci

# Expose port
EXPOSE 3000

# Start the dev server. On first boot the database will be empty; open
# http://localhost:3000/install in a browser to run the in-app installer
# (validate → migrate → create-admin → finalize), which applies the
# Drizzle migrations and seeds reference data.
CMD ["npm", "run", "dev"]
